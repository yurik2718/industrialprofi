<% canonical_url("#{site_config.url}/") %>

<% content_for(:head) do %>
  <%= json_ld_tag(website_json_ld) %>
<% end %>

<section class="section">
  <div class="container">
    <div class="txt-align-center">
      <h1 class="section-title"><%= t("paths.title") %></h1>
      <p class="section-subtitle"><%= t("paths.subtitle") %></p>
    </div>

    <% if @paths.any? %>
      <%= render "path_card", path: @paths.first, featured: true,
            completed_count: @completed_counts.fetch(@paths.first.id, 0) %>

      <% if @paths.size > 1 %>
        <div class="card-grid card-grid--3-col">
          <% @paths.drop(1).each do |path| %>
            <%= render "path_card", path: path, completed_count: @completed_counts.fetch(path.id, 0) %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</section>
