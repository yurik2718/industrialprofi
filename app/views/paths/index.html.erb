<% meta_title(t("paths.title")) %>
<% meta_description(t("paths.subtitle")) %>
<% canonical_url("#{site_config.url}/paths") %>

<section class="section">
  <div class="container">
    <%= render "shared/breadcrumbs", crumbs: [
      { title: t("paths.title") }
    ] %>

    <div class="txt-align-center">
      <h1 class="section-title"><%= t("paths.title") %></h1>
      <p class="section-subtitle"><%= t("paths.subtitle") %></p>
    </div>

    <div class="landing-grid landing-grid--cards">
      <% @paths.each do |path| %>
        <a href="<%= path_path(path) %>" class="panel panel--hover">
          <h2 class="panel__title"><%= path.title %></h2>
          <p class="panel__description"><%= path.description %></p>
          <div class="panel__meta">
            <span><%= russian_pluralize(path.lessons_count, :lesson) %></span>
          </div>
        </a>
      <% end %>
    </div>
  </div>
</section>
