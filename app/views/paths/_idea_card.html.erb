<%# A lightweight "name a profession we're missing" invite at the tail of the
    "Скоро" grid — the open end of the demand signal (the toggle covers planned
    professions; this catches the ones the founder hasn't thought of). Funnels to
    the existing feedback line — a profession idea IS feedback — tagged so it
    stands out in the inbox. NOT the curator card: that asks you to LEAD a map. -%>
<a href="<%= new_feedback_path(about: "profession", from: paths_path) %>"
   class="panel panel--hover path-card path-card--curator">
  <div class="path-card__head">
    <span class="path-card__icon"><%= heroicon "light-bulb", variant: :outline %></span>
    <h2 class="path-card__title"><%= t("paths.idea_card_title") %></h2>
  </div>
  <div class="path-card__foot">
    <span class="path-card__meta"><%= t("paths.idea_card_meta") %></span>
  </div>
</a>
