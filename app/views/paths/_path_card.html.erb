<%# locals: (path:, completed_count: 0) -%>
<% if path.stub? %>
  <div class="panel path-card path-card--soon" aria-disabled="true">
    <div class="path-card__head">
      <span class="path-card__icon"><%= topic_icon_svg(path_icon_token(path)) %></span>
      <h2 class="path-card__title"><%= path.title %></h2>
    </div>
    <div class="path-card__foot">
      <span class="badge <%= path.coming_soon? ? "badge--progress" : "badge--planned" %>"><%= t("paths.#{path.status}") %></span>
    </div>
  </div>
<% else %>
  <a href="<%= path_path(path) %>" class="panel panel--hover path-card">
    <div class="path-card__head">
      <span class="path-card__icon"><%= topic_icon_svg(path_icon_token(path)) %></span>
      <h2 class="path-card__title"><%= path.title %></h2>
      <span class="path-card__arrow" aria-hidden="true"><%= heroicon "arrow-right", variant: :outline %></span>
    </div>
    <div class="path-card__foot">
      <% if completed_count.positive? %>
        <%= render "shared/progress_bar", completed: completed_count, total: path.lessons_count %>
      <% else %>
        <span class="path-card__meta"><%= russian_pluralize(path.lessons_count, :lesson) %></span>
      <% end %>
    </div>
  </a>
<% end %>
