<% meta_title(@path.title) %>
<% meta_description(@path.description.to_s.truncate(160)) %>
<% canonical_url("#{site_config.url}/paths/#{@path.slug}") %>

<% content_for(:head) do %>
  <%= json_ld_tag(course_json_ld(@path)) %>
  <%= json_ld_tag(breadcrumb_json_ld([
    { title: t("breadcrumbs.home"), url: "#{site_config.url}/" },
    { title: t("paths.title"), url: "#{site_config.url}/paths" },
    { title: @path.title, url: "#{site_config.url}/paths/#{@path.slug}" }
  ])) %>
<% end %>

<section class="section">
  <div class="container container--reading">
    <div class="path-hero">
      <div class="topic-hero-icon">
        <%= topic_icon_svg(path_icon_token(@path)) %>
      </div>
      <h1 class="path__title"><%= @path.title %></h1>
    </div>

    <div class="path__overview">
      <p class="path__overview-text"><%= @path.description %></p>
    </div>

    <div class="path__start">
      <% if signed_in? && @completed_ids.any? %>
        <%= render "shared/progress_bar", completed: @completed_ids.size, total: @path.lessons_count %>
        <% if @continue_lesson %>
          <%= link_to @continue_lesson, class: "btn btn--reversed btn--large" do %>
            <%= t("paths.continue_learning") %>
            <%= heroicon "arrow-right", variant: :outline %>
          <% end %>
          <p class="path__continue-hint"><%= t("paths.next_up", title: @continue_lesson.title) %></p>
        <% end %>
      <% elsif @continue_lesson %>
        <%= link_to @continue_lesson, class: "btn btn--reversed btn--large" do %>
          <%= t("paths.start_learning") %>
          <%= heroicon "arrow-right", variant: :outline %>
        <% end %>
      <% end %>
    </div>

    <div class="curriculum">
      <% @courses.each_with_index do |course, index| %>
        <% completed = @completed_by_course[course.id] || 0 %>
        <% total = course.lessons_count %>
        <% course_done = signed_in? && total.positive? && completed == total %>
        <div class="curriculum__stage-row">
          <span class="curriculum__marker<%= " curriculum__marker--done" if course_done %>" aria-hidden="true">
            <% if course_done %>
              <%= heroicon "check", variant: :outline %>
            <% elsif course.coming_soon? %>
              <%= heroicon "lock-closed", variant: :outline %>
            <% else %>
              <%= index + 1 %>
            <% end %>
          </span>

          <% if course.coming_soon? %>
            <div class="curriculum__section curriculum__course curriculum__course--soon">
              <div class="curriculum__header">
                <h2 class="curriculum__header-title"><%= course.title %></h2>
                <span class="badge badge--draft"><%= t("courses.coming_soon") %></span>
              </div>
              <% if course.description.present? %>
                <p class="curriculum__course-desc"><%= course.description %></p>
              <% end %>
            </div>
          <% else %>
            <%= link_to course_path(course), class: "curriculum__section curriculum__course" do %>
              <div class="curriculum__header">
                <h2 class="curriculum__header-title"><%= course.title %></h2>
                <% if signed_in? && total.positive? %>
                  <span class="curriculum__header-count<%= " curriculum__header-count--done" if course_done %>"><%= completed %>/<%= total %></span>
                <% end %>
              </div>
              <% if course.description.present? %>
                <p class="curriculum__course-desc"><%= course.description %></p>
              <% end %>
              <span class="curriculum__course-cta">
                <%= t("courses.open") %>
                <%= heroicon "arrow-right", variant: :outline %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%= render "shared/support_cta" %>
