<% meta_title(@path.title) %>
<% meta_description(@path.description.to_s.truncate(160)) %>
<% canonical_url("#{site_config.url}/paths/#{@path.slug}") %>

<% content_for(:head) do %>
  <%= json_ld_tag(course_json_ld(@path)) %>
  <%= json_ld_tag(breadcrumb_json_ld([
    { title: t("breadcrumbs.home"), url: "#{site_config.url}/" },
    { title: t("paths.title"), url: "#{site_config.url}/paths" },
    { title: @path.title, url: "#{site_config.url}/paths/#{@path.slug}" }
  ])) %>
<% end %>

<%# ── Header (centered, Odin-style) ── %>
<section class="py-12 sm:py-16">
  <div class="content-container text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full border-2 border-gold-500/60 text-gold-400 mb-6">
      <%= topic_icon_svg(@path.slug == "elektrik" ? "bolt" : @path.slug == "svarshchik" ? "fire" : @path.slug == "santehnik" ? "wrench" : "cog") %>
    </div>

    <h1 class="text-2xl sm:text-3xl font-bold text-white"><%= @path.title %></h1>

    <div class="mt-6 max-w-2xl mx-auto">
      <h2 class="text-base font-semibold text-gray-300"><%= t("paths.overview") %></h2>
      <p class="mt-2 text-sm text-gray-400 leading-relaxed"><%= @path.description %></p>
    </div>
  </div>
</section>

<%# ── Curriculum sections ── %>
<section class="pb-16">
  <div class="content-container">
    <div class="space-y-6">
      <% @lessons_by_stage.each do |stage, lessons| %>
        <div class="curriculum-section">
          <% if stage.present? %>
            <div class="curriculum-header">
              <h2 class="text-base font-semibold text-white"><%= stage %></h2>
            </div>
          <% end %>

          <div class="divide-y divide-gray-700/30">
            <% lessons.each do |lesson| %>
              <a href="<%= lesson_path(lesson) %>" class="flex items-center gap-3 px-6 py-3.5 hover:bg-navy-lighter/50 transition group">
                <% if lesson.kind == "practice" %>
                  <svg class="w-5 h-5 text-gray-500 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/>
                  </svg>
                <% else %>
                  <svg class="w-5 h-5 text-gray-500 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/>
                  </svg>
                <% end %>
                <span class="text-sm text-gray-300 group-hover:text-white transition"><%= lesson.title %></span>
              </a>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Support CTA (Odin-style) ── %>
<section class="border-t border-gray-700/50 bg-navy-light">
  <div class="page-container py-16 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-white"><%= t("landing.support_title") %></h2>
    <p class="mt-4 body-text max-w-lg mx-auto"><%= t("landing.support_subtitle") %></p>
    <div class="mt-8 flex items-center justify-center gap-4 flex-wrap">
      <a href="<%= support_us_path %>" class="btn-outline"><%= t("landing.contact_us_short") %></a>
      <a href="<%= site_config.donate_url %>" class="btn-primary" target="_blank" rel="noopener"><%= t("landing.donate") %></a>
    </div>
  </div>
</section>
