<% meta_title(@path.title) %>
<% meta_description(@path.description.to_s.truncate(160)) %>
<% canonical_url("#{site_config.url}/paths/#{@path.slug}") %>

<% content_for(:head) do %>
  <%= json_ld_tag(course_json_ld(@path)) %>
  <%= json_ld_tag(breadcrumb_json_ld([
    { title: t("breadcrumbs.home"), url: "#{site_config.url}/" },
    { title: t("paths.title"), url: "#{site_config.url}/paths" },
    { title: @path.title, url: "#{site_config.url}/paths/#{@path.slug}" }
  ])) %>
<% end %>

<section class="section">
  <div class="container container--reading">
    <div class="path-hero">
      <div class="topic-hero-icon">
        <%= render "shared/topic_badge", token: path_icon_token(@path) %>
      </div>
      <h1 class="path__title"><%= @path.title %></h1>
    </div>

    <div class="path__overview">
      <p class="path__overview-text"><%= @path.description %></p>
    </div>

    <% if @curators.any? %>
      <div class="path__curators">
        <span class="path__curators-label"><%= t("paths.curated_by") %></span>
        <% @curators.each do |curator| %>
          <span class="path__curator">
            <%= avatar_tag(curator.name) %>
            <span class="path__curator-text">
              <span class="path__curator-name"><%= curator.name %></span>
              <% if curator.headline.present? %>
                <span class="path__curator-headline"><%= curator.headline %></span>
              <% end %>
            </span>
          </span>
        <% end %>
      </div>
    <% end %>

    <div class="path__start">
      <% if signed_in? && @completed_ids.any? %>
        <%= render "shared/progress_bar", completed: @completed_ids.size, total: @path.lessons_count %>
        <% if @continue_lesson %>
          <%= link_to @continue_lesson, class: "btn btn--reversed btn--large" do %>
            <%= t("paths.continue_learning") %>
            <%= heroicon "arrow-right", variant: :outline %>
          <% end %>
          <p class="path__continue-hint"><%= t("paths.next_up", title: @continue_lesson.title) %></p>
        <% end %>
      <% elsif @continue_lesson %>
        <%= link_to @continue_lesson, class: "btn btn--reversed btn--large" do %>
          <%= t("paths.start_learning") %>
          <%= heroicon "arrow-right", variant: :outline %>
        <% end %>
      <% end %>
    </div>

    <div class="course-cards">
      <% @courses.each_with_index do |course, index| %>
        <%= render "course_card",
              course: course,
              completed: @completed_by_course[course.id] || 0,
              total: course.lessons_count,
              lessons_n: @kind_counts[[course.id, "lesson"]].to_i,
              practice_n: @kind_counts[[course.id, "practice"]].to_i %>
      <% end %>
    </div>

    <%# A single quiet link to the profession's document library — the full,
        type-grouped list lives on its own page (and the per-lesson resources show
        each source in context). Keeping it off the overview removes the visual
        noise of a flat document dump and matches the "right order, in context"
        thesis. %>
    <% if @has_library %>
      <p class="path__library-link">
        <a href="<%= resources_path(path: @path.slug) %>" class="link-quiet"><%= t("resources.section_link") %></a>
      </p>
    <% end %>
  </div>
</section>

<%= render "shared/support_cta" %>
