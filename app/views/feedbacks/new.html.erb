<% meta_title(@title || t("feedbacks.title")) %>
<% @layout_class = "main--centered" %>

<section class="section">
  <div class="container">
    <div class="feedback">
      <header class="feedback__head">
        <h1 class="feedback__title"><%= @title || t("feedbacks.title") %></h1>
        <p class="feedback__intro"><%= @intro || t("feedbacks.intro") %></p>
      </header>

      <%= render "admin/shared/form_errors", object: @feedback %>

      <%= form_with model: @feedback, class: "feedback__form" do |f| %>
        <%= f.hidden_field :page_url %>
        <div class="feedback__field">
          <%= f.label :body, t("feedbacks.body_label"), class: "feedback__label" %>
          <%= f.text_area :body, rows: 7, required: true, maxlength: 5_000, autofocus: true,
                placeholder: t("feedbacks.body_placeholder"), class: "input input--textarea" %>
        </div>
        <%= f.submit t("feedbacks.send"), class: "btn btn--reversed btn--large" %>
      <% end %>

      <p class="feedback__promise"><%= t("feedbacks.promise") %></p>
    </div>
  </div>
</section>
