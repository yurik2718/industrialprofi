<% canonical_url("#{site_config.url}/") %>

<% content_for(:head) do %>
  <%= json_ld_tag(website_json_ld) %>
<% end %>

<section class="section">
  <div class="container txt-align-center">
    <h1 class="page-title"><%= t("landing.hero_title_html") %></h1>
    <p class="lede"><%= t("landing.hero_subtitle") %></p>
    <div class="hero-actions">
      <a href="<%= paths_path %>" class="btn"><%= t("landing.browse_professions") %></a>
    </div>
  </div>

  <div class="container">
    <div class="hero-illustration">
      <div>
        <%= heroicon("arrows-up-down", variant: :outline) %>
        <p class="hero-illustration__caption"><%= t("landing.illustration_placeholder") %></p>
      </div>
    </div>
  </div>
</section>

<section id="how-it-works" class="section section--divided">
  <div class="container">
    <h2 class="section-title"><%= t("landing.how_it_works") %></h2>
    <p class="section-subtitle"><%= t("landing.how_it_works_subtitle") %></p>

    <div class="landing-grid landing-grid--gap-lg landing-grid--3-col">
      <div class="step">
        <div class="step-icon">
          <%= heroicon("book-open", variant: :outline) %>
        </div>
        <h3 class="step__title"><%= t("landing.step_learn") %></h3>
        <p class="step__desc"><%= t("landing.step_learn_desc") %></p>
      </div>

      <div class="step">
        <div class="step-icon">
          <%= heroicon("wrench-screwdriver", variant: :outline) %>
        </div>
        <h3 class="step__title"><%= t("landing.step_practice") %></h3>
        <p class="step__desc"><%= t("landing.step_practice_desc") %></p>
      </div>

      <div class="step">
        <div class="step-icon">
          <%= heroicon("user-group", variant: :outline) %>
        </div>
        <h3 class="step__title"><%= t("landing.step_grow") %></h3>
        <p class="step__desc"><%= t("landing.step_grow_desc") %></p>
      </div>
    </div>
  </div>
</section>

<section id="professions" class="section section--divided">
  <div class="container">
    <h2 class="section-title"><%= t("landing.explore_title") %></h2>

    <div class="landing-grid landing-grid--cards">
      <%= render "pages/topic_card", icon: "bolt",        title: t("landing.topic_electrical"),   subtitle: t("landing.topic_electrical_sub") %>
      <%= render "pages/topic_card", icon: "fire",        title: t("landing.topic_welding"),      subtitle: t("landing.topic_welding_sub") %>
      <%= render "pages/topic_card", icon: "wrench",      title: t("landing.topic_plumbing"),     subtitle: t("landing.topic_plumbing_sub") %>
      <%= render "pages/topic_card", icon: "cog",         title: t("landing.topic_installation"), subtitle: t("landing.topic_installation_sub") %>
      <%= render "pages/topic_card", icon: "thermometer", title: t("landing.topic_hvac"),         subtitle: t("landing.topic_hvac_sub") %>
      <%= render "pages/topic_card", icon: "shield",      title: t("landing.topic_safety"),       subtitle: t("landing.topic_safety_sub") %>
    </div>

    <div class="cta-row">
      <a href="<%= paths_path %>" class="btn"><%= t("landing.browse_all") %></a>
    </div>
  </div>
</section>

<section class="section section--divided">
  <div class="container">
    <h2 class="section-title"><%= t("landing.why_title") %></h2>

    <div class="landing-grid landing-grid--2-col">
      <div class="why-item">
        <div class="avatar">$</div>
        <div>
          <h4 class="why-item__title"><%= t("landing.why_salary") %></h4>
          <p class="why-item__desc"><%= t("landing.why_salary_desc") %></p>
        </div>
      </div>
      <div class="why-item">
        <div class="avatar">!</div>
        <div>
          <h4 class="why-item__title"><%= t("landing.why_deficit") %></h4>
          <p class="why-item__desc"><%= t("landing.why_deficit_desc") %></p>
        </div>
      </div>
      <div class="why-item">
        <div class="avatar">AI</div>
        <div>
          <h4 class="why-item__title"><%= t("landing.why_ai") %></h4>
          <p class="why-item__desc"><%= t("landing.why_ai_desc") %></p>
        </div>
      </div>
      <div class="why-item">
        <div class="avatar">СНГ</div>
        <div>
          <h4 class="why-item__title"><%= t("landing.why_cis") %></h4>
          <p class="why-item__desc"><%= t("landing.why_cis_desc") %></p>
        </div>
      </div>
    </div>

    <div class="cta-row">
      <a href="<%= site_config.telegram_url %>" class="subtle-link" target="_blank" rel="noopener">
        <%= t("landing.tell_story") %>
      </a>
    </div>
  </div>
</section>

<section id="support" class="support-cta">
  <div class="container support-cta__inner">
    <h2 class="support-cta__title"><%= t("landing.support_title") %></h2>
    <p class="support-cta__subtitle"><%= t("landing.support_subtitle") %></p>
    <div class="support-cta__buttons">
      <a href="<%= site_config.telegram_url %>" class="btn" target="_blank" rel="noopener"><%= t("landing.contact_us") %></a>
      <a href="<%= site_config.donate_url %>" class="btn btn--marker" target="_blank" rel="noopener"><%= t("landing.donate") %></a>
    </div>
  </div>
</section>
