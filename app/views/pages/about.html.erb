<% meta_title(t("about.title")) %>
<% meta_description(t("about.intro1").truncate(160)) %>
<% canonical_url("#{site_config.url}/about") %>

<section class="section">
  <div class="container container--reading">
    <article class="about-letter">
      <p class="about-letter__eyebrow"><%= t("about.eyebrow") %></p>
      <h1 class="about-letter__title"><%= t("about.title") %></h1>

      <div class="about-letter__body">
        <p class="about-letter__greeting"><%= t("about.greeting") %></p>
        <p><%= t("about.intro1") %></p>
        <p><%= t("about.intro2") %></p>

        <h2 class="about-letter__heading"><%= t("about.problem_title") %></h2>
        <p><%= t("about.problem1") %></p>
        <p><%= t("about.problem2_html") %></p>
        <p class="about-letter__highlight"><%= t("about.highlight_deficit") %></p>

        <h2 class="about-letter__heading"><%= t("about.chance_title") %></h2>
        <p><%= t("about.chance1") %></p>
        <p class="about-letter__highlight"><%= t("about.highlight_chance") %></p>
        <p><%= t("about.chance2_html") %></p>

        <h2 class="about-letter__heading"><%= t("about.how_title") %></h2>
        <p><%= t("about.how1") %></p>
        <p><%= t("about.how_practice") %></p>
        <p><%= t("about.how_docs") %></p>
        <p><%= t("about.how2") %></p>

        <h2 class="about-letter__heading"><%= t("about.vision_title") %></h2>
        <p><%= t("about.vision1_html", github_url: site_config.github_url) %></p>
        <p><%= t("about.vision2") %></p>
        <p class="about-letter__highlight"><%= t("about.highlight_world") %></p>
        <p><%= t("about.invite") %></p>
        <p><%= t("about.closing") %></p>
      </div>

      <div class="about-letter__signature">
        <p class="about-letter__sign-name"><%= t("about.signature_name") %></p>
        <p class="about-letter__sign-role"><%= t("about.signature_role") %></p>
      </div>

      <p class="about-letter__contact">
        <%= t("about.contact_html", telegram_url: site_config.telegram_url) %>
      </p>

      <div class="about-letter__cta">
        <a href="<%= paths_path %>" class="btn btn--reversed btn--large">
          <%= t("about.cta_explore") %>
        </a>
        <a href="<%= support_us_path %>" class="btn btn--large">
          <%= t("about.cta_support") %>
        </a>
      </div>
    </article>
  </div>
</section>
