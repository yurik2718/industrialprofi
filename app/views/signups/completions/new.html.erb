<% meta_title(t("signup.completion_title")) %>

<section class="section">
  <div class="container">
    <div class="auth">
      <%= render "shared/auth_brand" %>
      <h1 class="auth__title"><%= t("signup.completion_title") %></h1>
      <p class="auth__subtitle"><%= t("signup.completion_hint") %></p>

      <%= form_with model: @user, url: signup_completion_path, class: "auth__form" do |form| %>
        <% if @user.errors.any? %>
          <div class="auth__errors" role="alert">
            <ul>
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form.label :name, t("auth.name"), class: "for-screen-reader" %>
        <%= form.text_field :name, required: true, autofocus: true, autocomplete: "name",
              placeholder: t("auth.name_placeholder"), class: "input" %>

        <%= form.label :password, t("auth.password"), class: "for-screen-reader" %>
        <%= form.password_field :password, required: true, minlength: 8,
              autocomplete: "new-password", placeholder: t("auth.password_placeholder"), class: "input" %>

        <%= form.label :password_confirmation, t("auth.password_confirmation"), class: "for-screen-reader" %>
        <%= form.password_field :password_confirmation, required: true, minlength: 8,
              autocomplete: "new-password", placeholder: t("auth.password_confirmation"), class: "input" %>

        <%= form.button class: "btn btn--reversed btn--large auth__submit" do %>
          <%= t("signup.create_account") %>
          <%= heroicon "arrow-right", variant: :outline %>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
