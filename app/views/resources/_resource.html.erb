<li class="lesson-resource <%= resource.required? ? "lesson-resource--required" : "lesson-resource--optional" %>">
  <span aria-hidden="true" class="lesson-resource__marker"><%= resource.required? ? "★" : "○" %></span>
  <div>
    <a href="<%= resource.url %>" class="lesson-resource__link" target="_blank" rel="noopener">
      <%= resource.title %>
    </a>
    <% if resource.country_code.present? %>
      <span class="lesson-resource__country"><%= resource.country_code %></span>
    <% end %>
  </div>
</li>
