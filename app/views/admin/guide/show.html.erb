<% meta_title(t("admin.guide.title")) %>

<%# Author's reference. The badges and callouts below are rendered with the SAME
    helpers production uses, so this page is always in sync. Prose is inline (a
    static Russian doc), labels come from the shared i18n. %>
<% type_notes = {
     "norm"     => "Официальный обязательный документ: ГОСТ, ПУЭ, ПТЭЭП, СП, СНиП, НАКС, РД, приказы, а также международные IEC / ISO / ASME / EN / DIN. Спина контента — где тема регулируется, ссылаемся на первоисточник, а не на пересказ.",
     "book"     => "Учебник, справочник, руководство — систематическое изложение темы (справочник электрика, учебник по сварке). Когда нужна глубина и контекст, а не одна норма.",
     "doc"      => "Документация производителя: даташит, техпаспорт, руководство по эксплуатации, каталог. Привязана к конкретному изделию — особенно важно для КИПиА (датчик, ПЛК, реле). Это паспорт прибора, а не норматив и не учебник.",
     "course"   => "Структурированная программа обучения: онлайн-курс, ДПО, учебный центр, видеокурс. Целая программа, а не один материал; часто платная.",
     "video"    => "Видеоразбор или демонстрация — YouTube, запись вебинара. Когда показать важнее, чем описать: монтаж, приёмы, работа прибором.",
     "article"  => "Статья, разбор, объяснение — habr-стиль, экспертный блог. Хорошо объясняет тему простым языком, дополняя норматив.",
     "software" => "Программа или веб-сервис, которым работают: Modbus Poll, UaExpert, Wireshark, онлайн-калькулятор, конфигуратор. То, что запускают, а не читают.",
     "tool"     => "Физический инструмент или материал для практики — ссылка, где приобрести (мультиметр, указатель напряжения, набор для пайки). Для практических заданий: «что понадобится и где взять»."
   } %>
<% callout_notes = {
     "ОПАСНО"  => { sample: "Работы под напряжением без снятия и проверки отсутствия напряжения недопустимы.",
                    when: "Угроза жизни, здоровью или оборудованию: напряжение, давление, высота, газ. Только по делу — иначе блок перестают замечать." },
     "ВАЖНО"   => { sample: "Группа III «до 1000 В» не даёт права работать в установках 6–10 кВ.",
                    when: "Ключевой факт, который легко упустить и дорого ошибиться, но это не прямая угроза жизни." },
     "СОВЕТ"   => { sample: "Для опрессовки наконечников удобнее гидравлический пресс, а не ручные клещи.",
                    when: "Практическая рекомендация, лайфхак, какой инструмент удобнее. Необязательное, но полезное." },
     "ПРИМЕР"  => { sample: "Ток нагрузки 25 А → сечение по таблице ПУЭ → автомат 25 А, кабель 4 мм².",
                    when: "Разобранный пример или расчёт, пошагово и с числами — показать применение нормы на конкретике." },
     "ПРОВЕРЬ" => { sample: "В каких установках действует ваша группа допуска и почему это указано в удостоверении?",
                    when: "Блок самопроверки в конце теории: вопросы со ссылкой на норматив, заставляющие думать, а не вспоминать." }
   } %>

<section class="admin-page">
  <div class="container container--reading">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <h1 class="admin-header__title"><%= t("admin.guide.title") %></h1>
    </div>
    <p class="admin-form__hint guide__intro"><%= t("admin.guide.intro") %></p>

    <section class="section">
      <h2 class="guide__heading">Типы ссылок</h2>
      <p class="guide__lead">Тип отвечает на вопрос «что это». Один тип на ссылку. Принцип — тип по делу: где тема регулируется, ставим первоисточник (Норматив); где нет — лучший качественный источник, честно помеченный.</p>
      <dl class="guide-types">
        <% type_notes.each do |kind, note| %>
          <div class="guide-type">
            <dt><%= resource_kind_badge(Resource.new(kind: kind)) %></dt>
            <dd><%= note %></dd>
          </div>
        <% end %>
      </dl>
    </section>

    <section class="section">
      <h2 class="guide__heading">Маркеры</h2>
      <p class="guide__lead">Маркер — вторая ось, поверх типа. У ссылки может быть ноль или несколько; маркер не меняет тип и не влияет на порядок.</p>
      <dl class="guide-types">
        <div class="guide-type">
          <dt><span class="badge badge--lang">EN</span> <span class="badge badge--lang">DE</span></dt>
          <dd>Язык источника, когда у материала нет качественного русского аналога. Мы честно берём лучшую мировую практику (Германия, США, Япония) и помечаем язык, чтобы учащийся понимал: материал не на русском. По умолчанию язык русский — без бейджа.</dd>
        </div>
        <div class="guide-type">
          <dt><span class="badge badge--draft">Партнёрский · планируется</span></dt>
          <dd>Для будущих реферальных/спонсорских ссылок: прозрачная пометка «Реклама/Партнёрский», только для администратора, не влияет на порядок выдачи, с обязательной юридической маркировкой (ОРД/ERID). Пока не активно — механизм маркеров готов, тип включим вместе с монетизацией.</dd>
        </div>
      </dl>
    </section>

    <section class="section">
      <h2 class="guide__heading">Текстовые блоки</h2>
      <p class="guide__lead">Цветные блоки внутри текста урока. Пишутся в markdown: строка <code>&gt; [!ВАЖНО]</code>, далее — текст блока. Цвет означает смысл; ставьте по делу, не для украшения.</p>
      <% callout_notes.each do |key, info| %>
        <div class="guide-callout">
          <%= markdown("> [!#{key}] #{info[:sample]}") %>
          <p class="guide-callout__when"><strong>Когда:</strong> <%= info[:when] %></p>
          <pre class="guide-callout__syntax"><code>&gt; [!<%= key %>] текст блока…</code></pre>
        </div>
      <% end %>
    </section>
  </div>
</section>
