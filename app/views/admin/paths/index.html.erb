<% meta_title(t("admin.paths_title")) %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <h1 class="admin-header__title"><%= t("admin.paths_title") %></h1>
      <div class="admin-header__actions">
        <a href="<%= new_admin_path_path %>" class="btn btn--small btn--reversed">
          <%= heroicon("plus", variant: :outline) %>
          <span><%= t("admin.new_path") %></span>
        </a>
      </div>
    </div>

    <div class="admin-list">
      <% @paths.each do |path| %>
        <a href="<%= edit_admin_path_path(path) %>" class="admin-row">
          <span class="admin-row__lead">
            <span class="admin-row__position"><%= path.position %></span>
            <span class="admin-row__title"><%= path.title %></span>
            <span class="badge <%= path.status == 'published' ? 'badge--link' : 'badge--draft' %>">
              <%= path.status %>
            </span>
          </span>
          <span class="admin-row__meta">
            <span><%= russian_pluralize(path.lessons_count, :lesson) %></span>
            <%= heroicon("pencil-square", variant: :outline) %>
          </span>
        </a>
      <% end %>
    </div>
  </div>
</section>
