<% meta_title(t("admin.paths_title")) %>

<section class="section-padded">
  <div class="page-container">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-white"><%= t("admin.paths_title") %></h1>
      <a href="<%= admin_lessons_path %>" class="btn-outline text-xs px-3 py-1.5"><%= t("admin.manage_lessons") %></a>
    </div>

    <div class="space-y-2">
      <% @paths.each do |path| %>
        <a href="<%= edit_admin_path_path(path) %>"
           class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-navy-lighter/50 transition group">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-xs text-gray-500 w-6 text-right"><%= path.position %></span>
            <span class="text-sm text-gray-300 group-hover:text-white transition truncate"><%= path.title %></span>
            <span class="text-xs px-2 py-0.5 rounded-full shrink-0 <%= path.status == 'published' ? 'bg-teal-900/50 text-teal-400' : 'bg-gray-700 text-gray-400' %>">
              <%= path.status %>
            </span>
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <span class="text-xs text-gray-500"><%= russian_pluralize(path.lessons_count, :lesson) %></span>
            <%= heroicon("pencil-square", variant: :outline, options: { class: "w-4 h-4 text-gray-600 group-hover:text-gray-400 transition" }) %>
          </div>
        </a>
      <% end %>
    </div>
  </div>
</section>
