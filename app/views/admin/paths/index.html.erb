<% meta_title(t("admin.paths_title")) %>

<section class="section-padded">
  <div class="page-container">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-ink"><%= t("admin.paths_title") %></h1>
      <a href="<%= admin_lessons_path %>" class="btn btn--small"><%= t("admin.manage_lessons") %></a>
    </div>

    <div class="space-y-2">
      <% @paths.each do |path| %>
        <a href="<%= edit_admin_path_path(path) %>"
           class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-subtle-light transition group">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-xs text-ink-subtle w-6 text-right"><%= path.position %></span>
            <span class="text-sm text-ink group-hover:text-ink transition truncate"><%= path.title %></span>
            <span class="text-xs px-2 py-0.5 rounded-full shrink-0 <%= path.status == 'published' ? 'bg-link/20 text-link' : 'bg-subtle text-ink-subtle' %>">
              <%= path.status %>
            </span>
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <span class="text-xs text-ink-subtle"><%= russian_pluralize(path.lessons_count, :lesson) %></span>
            <%= heroicon("pencil-square", variant: :outline, options: { class: "w-4 h-4 text-ink-subtle/70 group-hover:text-ink-subtle transition" }) %>
          </div>
        </a>
      <% end %>
    </div>
  </div>
</section>
