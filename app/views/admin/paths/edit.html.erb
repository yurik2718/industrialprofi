<% meta_title("#{t('admin.edit_path')} — #{@path.title}") %>

<section class="py-6">
  <div class="page-container max-w-3xl">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <a href="<%= admin_paths_path %>" class="text-ink-subtle hover:text-ink transition">
          <%= heroicon("arrow-left", variant: :outline, options: { class: "w-5 h-5" }) %>
        </a>
        <h1 class="text-xl font-bold text-ink"><%= @path.title %></h1>
      </div>
      <a href="<%= path_path(@path) %>" class="nav-link text-xs" target="_blank"><%= t("admin.view_live") %> ↗</a>
    </div>

    <%= render "admin/shared/form_errors", object: @path %>

    <%= form_with(model: [:admin, @path], url: admin_path_path(@path), method: :patch) do |f| %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-ink-subtle mb-1"><%= t("admin.field_title") %></label>
        <%= f.text_field :title, class: "w-full bg-subtle border border-subtle rounded-lg px-3 py-2 text-sm text-ink focus:outline-none focus:border-link/50 transition" %>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-ink-subtle mb-1"><%= t("admin.field_slug") %></label>
        <%= f.text_field :slug, class: "w-full bg-subtle border border-subtle rounded-lg px-3 py-2 text-sm text-ink-subtle font-mono focus:outline-none focus:border-link/50 transition" %>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-ink-subtle mb-1"><%= t("admin.field_description") %></label>
        <%= f.text_area :description, rows: 4, class: "w-full bg-subtle border border-subtle rounded-lg px-3 py-2 text-sm text-ink focus:outline-none focus:border-link/50 transition resize-y" %>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-ink-subtle mb-1"><%= t("admin.field_status") %></label>
        <%= f.select :status, %w[draft pending_review published],
            {}, class: "bg-subtle border border-subtle rounded-lg px-3 py-2 text-sm text-ink focus:outline-none focus:border-link/50 transition" %>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit t("admin.save"), class: "btn-primary cursor-pointer" %>
        <a href="<%= admin_paths_path %>" class="btn-outline"><%= t("admin.cancel") %></a>
      </div>
    <% end %>
  </div>
</section>
