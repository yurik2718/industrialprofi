<% meta_title("#{t('admin.edit_path')} — #{@path.title}") %>

<section class="py-6">
  <div class="page-container max-w-3xl">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <a href="<%= admin_paths_path %>" class="text-gray-500 hover:text-white transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
          </svg>
        </a>
        <h1 class="text-xl font-bold text-white"><%= @path.title %></h1>
      </div>
      <a href="<%= path_path(@path) %>" class="nav-link text-xs" target="_blank"><%= t("admin.view_live") %> ↗</a>
    </div>

    <%= render "admin/shared/form_errors", object: @path %>

    <%= form_with(model: [:admin, @path], url: admin_path_path(@path), method: :patch) do |f| %>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("admin.field_title") %></label>
        <%= f.text_field :title, class: "w-full bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-teal-500/50 transition" %>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("admin.field_slug") %></label>
        <%= f.text_field :slug, class: "w-full bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-gray-400 font-mono focus:outline-none focus:border-teal-500/50 transition" %>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("admin.field_description") %></label>
        <%= f.text_area :description, rows: 4, class: "w-full bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-gray-300 focus:outline-none focus:border-teal-500/50 transition resize-y" %>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("admin.field_status") %></label>
        <%= f.select :status, %w[draft pending_review published],
            {}, class: "bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-teal-500/50 transition" %>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit t("admin.save"), class: "btn-primary cursor-pointer" %>
        <a href="<%= admin_paths_path %>" class="btn-outline"><%= t("admin.cancel") %></a>
      </div>
    <% end %>
  </div>
</section>
