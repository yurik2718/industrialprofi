<% meta_title("#{t('admin.edit_path')} — #{@path.title}") %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <div class="admin-header__title-group">
        <a href="<%= admin_path_path(@path) %>" class="admin-header__back" aria-label="<%= t('admin.back') %>">
          <%= heroicon("arrow-left", variant: :outline) %>
        </a>
        <h1 class="admin-header__title"><%= @path.title %></h1>
      </div>
      <a href="<%= path_path(@path) %>" class="admin-header__view-live link-quiet" target="_blank"><%= t("admin.view_live") %> ↗</a>
    </div>

    <%= render "admin/paths/form", path: @path %>

    <% if Current.user.can_administer? %>
      <div class="admin-danger">
        <h2 class="admin-danger__title"><%= t("admin.builder.danger_zone") %></h2>
        <%= button_to t("admin.builder.delete_path"), admin_path_path(@path), method: :delete,
              class: "btn btn--negative btn--small",
              data: { turbo_confirm: t("admin.builder.delete_path_confirm", title: @path.title) } %>
      </div>
    <% end %>
  </div>
</section>
