<%# Shared by new + edit. form_with routes to create/update by record state. %>
<%= form_with(model: [ :admin, course ]) do |f| %>
  <%= render "admin/shared/form_errors", object: course %>

  <% if course.new_record? %>
    <div class="admin-form__field">
      <label><%= t("admin.field_path") %></label>
      <%= f.collection_select :path_id, Path.ordered, :id, :title,
            { prompt: t("admin.choose_path") }, class: "input" %>
    </div>
  <% end %>

  <div class="admin-form__field">
    <label><%= t("admin.field_title") %></label>
    <%= f.text_field :title, class: "input" %>
  </div>

  <div class="admin-form__field">
    <label><%= t("admin.field_slug") %></label>
    <%= f.text_field :slug, class: "input input--mono", placeholder: t("admin.slug_auto") %>
    <p class="admin-form__hint"><%= t("admin.slug_hint") %></p>
  </div>

  <% unless course.new_record? %>
    <div class="admin-form__field">
      <label><%= t("admin.field_position") %></label>
      <%= f.number_field :position, class: "input" %>
    </div>
  <% end %>

  <div class="admin-form__field">
    <label><%= t("admin.field_description") %></label>
    <%= f.text_area :description, rows: 4, class: "input input--textarea" %>
  </div>

  <%= render "admin/shared/status_field", f: f, record: course %>

  <div class="admin-form__actions">
    <%= f.submit t("admin.save"), class: "btn btn--reversed" %>
    <a href="<%= admin_courses_path %>" class="btn"><%= t("admin.cancel") %></a>
  </div>
<% end %>
