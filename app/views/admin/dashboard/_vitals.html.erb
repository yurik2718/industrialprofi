<%# The VPS vital-sign cards — lazy-loaded (see dashboard#vitals) because they
    run a `df` shell-out and Solid Queue probes. Sit inside the .admin-stats grid. -%>
<%# Disk safety — the metric that guards the single SQLite disk. Free space
    is the headline; the database footprint is the detail. Red when low. %>
<div class="panel admin-stat <%= "admin-stat--warn" if @status.disk_low? %>">
  <span class="admin-stat__value">
    <%= @status.disk_free_bytes ? number_to_human_size(@status.disk_free_bytes) : "—" %>
  </span>
  <span class="admin-stat__label"><%= t("admin.dashboard.disk_free") %></span>
  <span class="admin-stat__detail">
    <%= t("admin.dashboard.database_size",
          size: @status.database_bytes ? number_to_human_size(@status.database_bytes) : "—") %>
  </span>
</div>

<%# Mail flow — a sudden zero means the SMTP-gated signup funnel is broken.
    Counts delivered messages over the last 7 days (Solid Cache). %>
<div class="panel admin-stat">
  <span class="admin-stat__value"><%= @emails_week.nil? ? "—" : @emails_week %></span>
  <span class="admin-stat__label"><%= t("admin.dashboard.emails_week") %></span>
  <span class="admin-stat__detail"><%= t("admin.dashboard.emails_week_hint") %></span>
</div>

<%# Background-job health (Solid Queue) — shown only where the queue runs
    (production). `failed` is the alarm: a silently dying mailer/job. %>
<% if (jobs = @status.jobs) %>
  <div class="panel admin-stat <%= "admin-stat--warn" if jobs[:failed].positive? %>">
    <span class="admin-stat__value"><%= jobs[:failed] %></span>
    <span class="admin-stat__label"><%= t("admin.dashboard.jobs_failed") %></span>
    <span class="admin-stat__detail"><%= t("admin.dashboard.jobs_pending", count: jobs[:pending]) %></span>
  </div>
<% end %>
