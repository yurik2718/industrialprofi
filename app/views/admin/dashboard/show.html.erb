<% meta_title(t("admin.dashboard.title")) %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <h1 class="admin-header__title"><%= t("admin.dashboard.title") %></h1>
    </div>

    <% if @pending_suggestions.positive? %>
      <a href="<%= admin_lesson_suggestions_path %>" class="panel panel--hover admin-callout">
        <span class="admin-callout__text">
          <%= t("admin.dashboard.pending_suggestions", count: @pending_suggestions) %>
        </span>
        <span class="btn btn--small btn--reversed"><%= t("admin.dashboard.review_now") %></span>
      </a>
    <% end %>

    <div class="admin-stats">
      <div class="panel admin-stat">
        <span class="admin-stat__value"><%= @users_total %></span>
        <span class="admin-stat__label"><%= t("admin.dashboard.users_total") %></span>
        <span class="admin-stat__detail">
          <%= t("admin.dashboard.users_week", count: @users_week) %> ·
          <%= t("admin.dashboard.users_month", count: @users_month) %>
        </span>
      </div>

      <div class="panel admin-stat">
        <span class="admin-stat__value"><%= @active_week %></span>
        <span class="admin-stat__label"><%= t("admin.dashboard.active_week") %></span>
        <span class="admin-stat__detail"><%= t("admin.dashboard.active_week_hint") %></span>
      </div>

      <div class="panel admin-stat">
        <span class="admin-stat__value"><%= @completions_total %></span>
        <span class="admin-stat__label"><%= t("admin.dashboard.completions") %></span>
        <span class="admin-stat__detail"><%= t("admin.dashboard.completions_week", count: @completions_week) %></span>
      </div>

      <div class="panel admin-stat">
        <span class="admin-stat__value"><%= @journal_entries_total %></span>
        <span class="admin-stat__label"><%= t("admin.dashboard.journal_entries") %></span>
        <span class="admin-stat__detail"><%= t("admin.dashboard.journal_hint") %></span>
      </div>

      <%# VPS vital signs (disk, mail, jobs) load in their own frame — they run a
          `df` shell-out + queue probes, so splitting them off lets the rest of
          the dashboard paint at once while these fetch in parallel. The frame is
          eager (default): it's above the fold, so fetch immediately, not on
          scroll — and #dashboard_vitals is display:contents (no box of its own,
          which is why lazy/IntersectionObserver wouldn't fire here) so its cards
          drop straight into this grid. %>
      <%= turbo_frame_tag :dashboard_vitals, src: admin_dashboard_vitals_path do %>
        <% 3.times do %>
          <div class="panel admin-stat admin-stat--skeleton" aria-hidden="true">
            <span class="admin-stat__value">&nbsp;</span>
            <span class="admin-stat__label"></span>
          </div>
        <% end %>
      <% end %>
    </div>

    <%= render "bar_chart", title: t("admin.dashboard.signups_chart"),
          data: @signups_by_week, week_title_key: "admin.dashboard.signups_week_title" %>

    <%= render "bar_chart", title: t("admin.dashboard.completions_chart"),
          data: @completions_by_week, week_title_key: "admin.dashboard.completions_week_title" %>

    <div class="admin-group">
      <div class="admin-group__head">
        <h2 class="admin-group__title"><%= t("admin.dashboard.content") %></h2>
      </div>
      <div class="admin-list">
        <a href="<%= admin_paths_path %>" class="admin-row">
          <span class="admin-row__title"><%= t("admin.dashboard.content_paths") %></span>
          <span class="admin-row__meta">
            <%= t("admin.dashboard.published_of_total", published: @paths_published, total: @paths_total) %>
          </span>
        </a>
        <a href="<%= admin_courses_path %>" class="admin-row">
          <span class="admin-row__title"><%= t("admin.dashboard.content_courses") %></span>
          <span class="admin-row__meta"><%= @courses_total %></span>
        </a>
        <a href="<%= admin_lessons_path %>" class="admin-row">
          <span class="admin-row__title"><%= t("admin.dashboard.content_lessons") %></span>
          <span class="admin-row__meta"><%= @lessons_total %></span>
        </a>
      </div>
    </div>

    <div class="admin-group">
      <div class="admin-group__head">
        <h2 class="admin-group__title"><%= t("admin.dashboard.recent_users") %></h2>
        <a href="<%= admin_users_path %>" class="admin-group__meta"><%= t("admin.dashboard.all_users") %> →</a>
      </div>
      <div class="admin-list">
        <% @recent_users.each do |user| %>
          <div class="admin-row admin-row--static">
            <span class="admin-row__line">
              <span class="admin-row__title"><%= user.name %></span>
              <% unless user.member? %>
                <span class="badge badge--marker"><%= t("admin.roles.#{user.role}") %></span>
              <% end %>
            </span>
            <span class="admin-row__subtle">
              <%= user.email_address %> · <%= l(user.created_at, format: :long) %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
