<% meta_title(t("admin.manage_feedbacks")) %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <div class="admin-header__title-group">
        <h1 class="admin-header__title"><%= t("admin.manage_feedbacks") %></h1>
      </div>
    </div>

    <% if @feedbacks.none? %>
      <div class="admin-empty">
        <p class="admin-empty__text"><%= t("admin.feedbacks_none") %></p>
      </div>
    <% else %>
      <%# Dense inbox: a compact row per message, full text on click (native
          <details>, no JS) so a long queue stays scannable. %>
      <ul class="inbox">
        <% @feedbacks.each do |feedback| %>
          <li class="inbox__item">
            <details class="inbox__entry">
              <summary class="inbox__summary">
                <span class="inbox__from"><%= feedback.user.name %></span>
                <span class="inbox__snippet"><%= truncate(feedback.body.to_s.squish, length: 100) %></span>
                <time class="inbox__date" datetime="<%= feedback.created_at.iso8601 %>">
                  <%= l(feedback.created_at, format: :short) %>
                </time>
              </summary>

              <div class="inbox__detail">
                <p class="inbox__meta">
                  <%= mail_to feedback.user.email_address, feedback.user.email_address, class: "link-quiet" %>
                  · <%= l(feedback.created_at, format: :long) %>
                  <% if feedback.page_url.present? %>
                    · <%= link_to t("admin.feedback_from_page"), feedback.page_url, class: "link-quiet" %>
                  <% end %>
                </p>
                <div class="inbox__body"><%= simple_format(feedback.body) %></div>
                <a href="mailto:<%= feedback.user.email_address %>?subject=<%= u t('admin.feedback_reply_subject') %>"
                   class="btn btn--small btn--reversed">
                  <%= t("admin.feedback_reply") %>
                </a>
              </div>
            </details>
          </li>
        <% end %>
      </ul>

      <%= render "admin/shared/pagination", page: @page, more: @has_more %>
    <% end %>
  </div>
</section>
