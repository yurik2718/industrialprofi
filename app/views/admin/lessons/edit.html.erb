<% meta_title("#{t('admin.edit_lesson')} — #{@lesson.title}") %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <div class="admin-header__title-group">
        <a href="<%= admin_lessons_path %>" class="admin-header__back" aria-label="<%= t('admin.back') %>">
          <%= heroicon("arrow-left", variant: :outline) %>
        </a>
        <h1 class="admin-header__title"><%= @lesson.title %></h1>
      </div>
      <div class="admin-header__actions">
        <% if @lesson.revised? %>
          <a href="<%= admin_lesson_revisions_path(@lesson) %>" class="btn btn--small"><%= t("revisions.history") %> (<%= @lesson.lesson_revisions_count %>)</a>
        <% end %>
        <a href="<%= lesson_path(@lesson) %>" class="admin-header__view-live link-quiet" target="_blank"><%= t("admin.view_live") %> ↗</a>
      </div>
    </div>

    <%= render "admin/shared/form_errors", object: @lesson %>

    <%= form_with(model: [:admin, @lesson], url: admin_lesson_path(@lesson), method: :patch) do |f| %>
      <div class="admin-form__field">
        <label><%= t("admin.field_title") %></label>
        <%= f.text_field :title, class: "input" %>
      </div>

      <div class="admin-form__field">
        <label><%= t("admin.field_kind") %></label>
        <%= f.select :kind, [[t("admin.kind_lesson"), "lesson"], [t("admin.kind_practice"), "practice"]],
            {}, class: "input" %>
      </div>

      <p class="admin-form__hint admin-form__field--lg"><%= t("admin.markdown_paste_hint") %></p>

      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("admin.field_description") %></label>
        <%= f.rich_text_area :rich_description, class: "lexxy-content" %>
      </div>

      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("admin.field_body") %></label>
        <%= f.rich_text_area :rich_body, class: "lexxy-content" %>
      </div>

      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("admin.field_task") %></label>
        <%= f.rich_text_area :rich_task, class: "lexxy-content" %>
      </div>

      <%# Live badge palette for the editor: one colour per kind, mirroring the
          reader's resource badges (documents skew "norm" red on this platform). %>
      <% kind_badges = {
           "document" => [ "badge--norm", t("lessons.resource_kinds.document") ],
           "video"    => [ "badge--video", t("lessons.resource_kinds.video") ],
           "article"  => [ "badge--article", t("lessons.resource_kinds.article") ],
           "tool"     => [ "badge--tool", t("lessons.resource_kinds.tool") ]
         } %>
      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("admin.resources.heading") %></label>
        <p class="admin-form__hint"><%= t("admin.resources.hint") %></p>

        <div class="resource-editor" data-controller="nested-form"
             data-nested-form-kinds-value="<%= kind_badges.to_json %>">
          <div class="resource-editor__list" data-nested-form-target="list"
               data-action="dragover->nested-form#dragOver">
            <%= f.fields_for :resources do |rf| %>
              <%= render "admin/lessons/resource_fields", f: rf %>
            <% end %>
          </div>

          <template data-nested-form-target="template">
            <%= f.fields_for :resources, Resource.new, child_index: "NEW_RECORD" do |rf| %>
              <%= render "admin/lessons/resource_fields", f: rf %>
            <% end %>
          </template>

          <button type="button" class="btn btn--small resource-editor__add"
                  data-action="nested-form#addItem">
            <%= heroicon "plus", variant: :outline %>
            <span><%= t("admin.resources.add") %></span>
          </button>
        </div>
      </div>

      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("revisions.reason") %></label>
        <p class="admin-form__hint"><%= t("revisions.reason_hint_admin") %></p>
        <%= text_field_tag "lesson[edit_reason]", nil, class: "input", placeholder: t("revisions.reason_placeholder") %>
      </div>

      <div class="admin-form__actions">
        <%= f.submit t("admin.save"), class: "btn btn--reversed" %>
        <a href="<%= admin_lessons_path %>" class="btn"><%= t("admin.cancel") %></a>
      </div>
    <% end %>
  </div>
</section>
