<% meta_title(t("admin.new_lesson")) %>

<section class="admin-page">
  <div class="container container--reading">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <div class="admin-header__title-group">
        <a href="<%= admin_lessons_path %>" class="admin-header__back" aria-label="<%= t('admin.back') %>">
          <%= heroicon("arrow-left", variant: :outline) %>
        </a>
        <h1 class="admin-header__title"><%= t("admin.new_lesson") %></h1>
      </div>
    </div>

    <p class="admin-form__hint admin-form__field--lg"><%= t("admin.new_lesson_hint") %></p>

    <%= render "admin/shared/form_errors", object: @lesson %>

    <%= form_with(model: [ :admin, @lesson ]) do |f| %>
      <div class="admin-form__field">
        <label><%= t("admin.field_course") %></label>
        <%= f.grouped_collection_select :course_id, @editable_paths,
              :courses, :title, :id, :title,
              { prompt: t("admin.choose_course") }, class: "input" %>
      </div>

      <div class="admin-form__field">
        <label><%= t("admin.field_stage") %></label>
        <%= f.text_field :stage, class: "input", placeholder: t("admin.stage_placeholder") %>
        <p class="admin-form__hint"><%= t("admin.stage_hint") %></p>
      </div>

      <div class="admin-form__field">
        <label><%= t("admin.field_title") %></label>
        <%= f.text_field :title, class: "input" %>
      </div>

      <div class="admin-form__field">
        <label><%= t("admin.field_slug") %></label>
        <%= f.text_field :slug, class: "input input--mono", placeholder: t("admin.slug_auto") %>
        <p class="admin-form__hint"><%= t("admin.slug_hint") %></p>
      </div>

      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("admin.field_kind") %></label>
        <%= f.select :kind, [ [ t("admin.kind_lesson"), "lesson" ], [ t("admin.kind_practice"), "practice" ] ],
            {}, class: "input" %>
      </div>

      <div class="admin-form__actions">
        <%= f.submit t("admin.create_lesson"), class: "btn btn--reversed" %>
        <a href="<%= admin_lessons_path %>" class="btn"><%= t("admin.cancel") %></a>
      </div>
    <% end %>
  </div>
</section>
