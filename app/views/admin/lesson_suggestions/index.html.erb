<% meta_title(t("admin.suggestions_title")) %>

<section class="section-padded">
  <div class="page-container">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-bold text-white"><%= t("admin.suggestions_title") %></h1>
      <div class="flex gap-3">
        <a href="<%= admin_lessons_path %>" class="btn-outline text-xs px-3 py-1.5"><%= t("admin.manage_lessons") %></a>
      </div>
    </div>

    <% if @suggestions.empty? %>
      <div class="text-center py-16 text-gray-500">
        <p class="text-lg"><%= t("admin.no_suggestions") %></p>
      </div>
    <% else %>
      <div class="space-y-2">
        <% @suggestions.each do |suggestion| %>
          <a href="<%= admin_lesson_suggestion_path(suggestion) %>"
             class="flex items-center justify-between px-4 py-3 rounded-lg hover:bg-navy-lighter/50 transition group">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm text-gray-300 group-hover:text-white transition truncate"><%= suggestion.lesson.title %></span>
                <span class="text-xs px-2 py-0.5 rounded-full bg-gold-500/20 text-gold-400"><%= suggestion.section %></span>
              </div>
              <p class="text-xs text-gray-500 mt-0.5">
                <%= suggestion.author_name %> · <%= time_ago_in_words(suggestion.created_at) %> <%= t("admin.ago") %>
              </p>
            </div>
            <svg class="w-4 h-4 text-gray-600 group-hover:text-gray-400 shrink-0 transition" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
            </svg>
          </a>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
