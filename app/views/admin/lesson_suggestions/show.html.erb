<% meta_title(t("admin.review_suggestion")) %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <div class="admin-header__title-group">
        <a href="<%= admin_lesson_suggestions_path %>" class="admin-header__back" aria-label="<%= t('admin.back') %>">
          <%= heroicon("arrow-left", variant: :outline) %>
        </a>
        <h1 class="admin-header__title"><%= t("admin.review_suggestion") %></h1>
      </div>
      <a href="<%= lesson_path(@lesson) %>" class="admin-header__view-live link-quiet" target="_blank"><%= t("admin.view_live") %> ↗</a>
    </div>

    <div class="admin-meta-card">
      <div class="admin-meta-card__row">
        <div>
          <span class="admin-meta-card__label"><%= t("admin.suggestion_lesson") %>:</span>
          <span class="admin-meta-card__value"><%= @lesson.title %></span>
        </div>
        <div>
          <span class="admin-meta-card__label"><%= t("admin.suggestion_section") %>:</span>
          <span class="admin-meta-card__value admin-meta-card__value--marker"><%= t("admin.field_#{@suggestion.section}") %></span>
        </div>
        <div>
          <span class="admin-meta-card__label"><%= t("admin.suggestion_author") %>:</span>
          <span class="admin-meta-card__value"><%= @suggestion.author_name %></span>
          <% if @suggestion.author_contact.present? %>
            <span class="admin-meta-card__value--subtle">(<%= @suggestion.author_contact %>)</span>
          <% end %>
        </div>
        <div>
          <span class="admin-meta-card__label"><%= t("admin.suggestion_date") %>:</span>
          <span class="admin-meta-card__value"><%= l(@suggestion.created_at, format: :long) %></span>
        </div>
      </div>
    </div>

    <% if @suggestion.stale? %>
      <div class="revision-stale">⚠ <%= t("revisions.stale_warning") %></div>
    <% end %>

    <% if @suggestion.edit_reason.present? %>
      <div class="admin-edit-reason">
        <span class="admin-meta-card__label"><%= t("revisions.reason") %>:</span>
        <span class="admin-meta-card__value"><%= @suggestion.edit_reason %></span>
      </div>
    <% end %>

    <% current_html  = @lesson.section_html(@suggestion.section) %>
    <% proposed_html = @suggestion.proposed_html %>

    <%# Two lenses, toggled client-side (no reload): «Рядом» reads each version on
        its own — legible at any edit size, the default — and «Изменения» is the
        inline word diff for pinning down a small, precise change. %>
    <div class="review-compare" data-controller="segmented" data-segmented-active-value="side">
      <div class="segmented" role="tablist">
        <button type="button" class="segmented__tab" data-segmented-target="tab" data-view="side"
                data-action="segmented#select"><%= t("admin.review.view_side") %></button>
        <button type="button" class="segmented__tab" data-segmented-target="tab" data-view="diff"
                data-action="segmented#select"><%= t("admin.review.view_diff") %></button>
      </div>

      <div class="review-split" data-segmented-target="panel" data-view="side">
        <div class="review-pane">
          <h3 class="review-pane__head review-pane__head--current"><%= t("admin.review.current") %></h3>
          <div class="review-pane__body prose"><%= safe_prose(current_html) %></div>
        </div>
        <div class="review-pane">
          <h3 class="review-pane__head review-pane__head--proposed"><%= t("admin.review.proposed") %></h3>
          <div class="review-pane__body prose"><%= safe_prose(proposed_html) %></div>
        </div>
      </div>

      <div class="review-diff" data-segmented-target="panel" data-view="diff" hidden>
        <div class="review-pane__body revision-diff prose"><%= inline_diff(current_html, proposed_html) %></div>
      </div>
    </div>

    <p class="admin-decision__hint"><%= t("admin.approve_hint") %></p>
    <div class="admin-decision">
      <%= button_to t("admin.approve"), approve_admin_lesson_suggestion_path(@suggestion),
            method: :patch, class: "btn btn--reversed btn--large",
            form: { class: "admin-decision__approve",
                    data: { turbo_confirm: t("admin.confirm_approve") } } %>

      <%= form_with(url: reject_admin_lesson_suggestion_path(@suggestion), method: :patch, class: "admin-decision__reject") do |f| %>
        <div class="admin-decision__reject-field">
          <label><%= t("admin.reject_comment") %></label>
          <%= f.text_field "lesson_suggestion[reviewer_comment]",
                placeholder: t("admin.reject_comment_placeholder"), class: "input" %>
        </div>
        <%= f.submit t("admin.reject"), class: "btn btn--negative" %>
      <% end %>
    </div>
  </div>
</section>
