<% meta_title(t("admin.users_title")) %>

<section class="admin-page">
  <div class="container">
    <%= render "admin/shared/nav" %>

    <div class="admin-header">
      <h1 class="admin-header__title"><%= t("admin.users_title") %></h1>
    </div>

    <%# Filter tabs — one query param each, search preserved. Switching a filter
        resets to page 1. Counts come from a single grouped query. %>
    <% filters = [
         [ t("admin.users.filter_all"),          {},                       @counts[:all],           params[:role].blank? && params[:status].blank? ],
         [ t("admin.roles.member"),               { role: "member" },        @counts[:member],        params[:role] == "member" ],
         [ t("admin.roles.editor"),               { role: "editor" },        @counts[:editor],        params[:role] == "editor" ],
         [ t("admin.roles.administrator"),        { role: "administrator" }, @counts[:administrator], params[:role] == "administrator" ],
         [ t("admin.users.filter_suspended"),     { status: "suspended" },   @counts[:suspended],     params[:status] == "suspended" ]
       ] %>
    <nav class="admin-filters" aria-label="<%= t("admin.users.filter_label") %>">
      <% filters.each do |label, query, count, active| %>
        <%= link_to url_for(query.merge(q: params[:q].presence)),
              class: "admin-filter#{' admin-filter--active' if active}",
              aria: { current: ("page" if active) } do %>
          <%= label %><span class="admin-filter__count"><%= count %></span>
        <% end %>
      <% end %>
    </nav>

    <%= form_with url: admin_users_path, method: :get, class: "admin-users-search" do %>
      <%= hidden_field_tag :role, params[:role] if params[:role].present? %>
      <%= hidden_field_tag :status, params[:status] if params[:status].present? %>
      <%= text_field_tag :q, params[:q], class: "input",
            placeholder: t("admin.users_search_placeholder") %>
      <%= submit_tag t("admin.users_search"), class: "btn" %>
    <% end %>

    <% if @users.empty? %>
      <div class="admin-empty">
        <p class="admin-empty__text"><%= t("admin.users_none") %></p>
      </div>
    <% else %>
      <p class="admin-list__summary"><%= t("admin.users.found", count: @total) %></p>

      <div class="admin-list">
        <% @users.each do |user| %>
          <%# Scan-and-navigate row: name + state, click through to manage. All
              role/access/suspend controls live on the user card now. %>
          <a href="<%= admin_user_path(user) %>" class="admin-row">
            <span class="admin-row__column">
              <span class="admin-row__line">
                <span class="admin-row__title"><%= user.name %></span>
                <% unless user.member? %>
                  <span class="badge badge--marker"><%= t("admin.roles.#{user.role}") %></span>
                <% end %>
                <% if user.suspended? %>
                  <span class="badge badge--draft"><%= t("admin.users.suspended_badge") %></span>
                <% end %>
                <% if user == Current.user %>
                  <span class="badge badge--draft"><%= t("admin.users_you") %></span>
                <% end %>
              </span>
              <p class="admin-row__subtle">
                <%= user.email_address %> · <%= l(user.created_at, format: :long) %>
              </p>
            </span>
            <span class="admin-row__meta">→</span>
          </a>
        <% end %>
      </div>

      <%= render "admin/shared/pagination", page: @page, more: @has_more, pages: @pages %>
    <% end %>
  </div>
</section>
