<%# Persistent section nav — identical links in identical order on EVERY admin
    page, so nothing moves or disappears when switching sections. The current
    section is highlighted; «Правки» carries the moderation-queue count. %>
<% section = { "dashboard" => "dashboard",
               "paths" => "program", "courses" => "program", "lessons" => "program", "revisions" => "program",
               "lesson_suggestions" => "suggestions", "imports" => "imports", "guide" => "guide",
               "users" => "users", "feedbacks" => "feedbacks", "admin_actions" => "log" }[controller_name] %>

<nav class="admin-nav" aria-label="<%= t("admin.nav_label") %>">
  <% if Current.user.can_administer? %>
    <%= link_to t("admin.dashboard.title"), admin_root_path, class: "admin-nav__link",
          aria: { current: ("page" if section == "dashboard") } %>
  <% end %>

  <%= link_to t("admin.manage_program"), admin_paths_path, class: "admin-nav__link",
        aria: { current: ("page" if section == "program") } %>

  <%= link_to admin_lesson_suggestions_path, class: "admin-nav__link",
        aria: { current: ("page" if section == "suggestions") } do %>
    <%= t("admin.manage_suggestions") %>
    <%= render "admin/shared/suggestions_count" %>
  <% end %>

  <%= link_to t("admin.manage_imports"), new_admin_import_path, class: "admin-nav__link",
        aria: { current: ("page" if section == "imports") } %>
  <%= link_to t("admin.manage_guide"), admin_guide_path, class: "admin-nav__link",
        aria: { current: ("page" if section == "guide") } %>

  <% if Current.user.can_administer? %>
    <%= link_to admin_feedbacks_path, class: "admin-nav__link",
          aria: { current: ("page" if section == "feedbacks") } do %>
      <%= t("admin.manage_feedbacks") %>
      <% if unread_feedbacks_count.positive? %>
        <span class="admin-nav__count"><%= unread_feedbacks_count %></span>
      <% end %>
    <% end %>
    <%= link_to t("admin.manage_users"), admin_users_path, class: "admin-nav__link",
          aria: { current: ("page" if section == "users") } %>
    <%= link_to t("admin.manage_log"), admin_log_path, class: "admin-nav__link",
          aria: { current: ("page" if section == "log") } %>
  <% end %>
</nav>
