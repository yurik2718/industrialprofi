<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for?(:title) ? content_for(:title) : "#{t('site.name')} — #{t('site.tagline')}" %></title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#000000">
    <meta name="description" content="<%= content_for?(:description) ? content_for(:description) : t('site.description') %>">
    <meta name="application-name" content="<%= t('site.name') %>">
    <meta name="robots" content="index, follow">
    <% if content_for?(:canonical) %>
      <link rel="canonical" href="<%= content_for(:canonical) %>">
    <% end %>

    <%# Open Graph %>
    <meta property="og:site_name" content="<%= t('site.name') %>">
    <meta property="og:locale" content="ru_RU">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= content_for?(:og_title) ? content_for(:og_title) : "#{t('site.name')} — #{t('site.tagline')}" %>">
    <meta property="og:description" content="<%= content_for?(:og_description) ? content_for(:og_description) : t('site.description') %>">
    <meta property="og:url" content="<%= content_for?(:canonical) ? content_for(:canonical) : request.original_url %>">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= content_for?(:og_title) ? content_for(:og_title) : "#{t('site.name')} — #{t('site.tagline')}" %>">
    <meta name="twitter:description" content="<%= content_for?(:og_description) ? content_for(:og_description) : t('site.description') %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :all, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="header">
      <nav class="container header__nav">
        <%= link_to root_path, class: "brand header__brand" do %>
          <%= image_tag "logo-ethernet.png", alt: "", class: "brand__mark", aria: { hidden: "true" } %>
          <span class="brand__text"><%= t("site.name") %></span>
        <% end %>
        <div class="header__links">
          <%= link_to t("nav.professions"), paths_path, class: "nav__link",
                aria: { current: ("page" if controller_name.in?(%w[paths lessons])) } %>
          <%= link_to t("nav.projects"), projects_path, class: "nav__link",
                aria: { current: ("page" if current_page?(projects_path)) } %>
          <%= link_to t("nav.about"), about_path, class: "nav__link",
                aria: { current: ("page" if current_page?(about_path)) } %>
          <%= link_to t("nav.support"), support_us_path, class: "nav__link",
                aria: { current: ("page" if current_page?(support_us_path)) } %>
          <% if controller.class.module_parent_name == "Admin" %>
            <span class="badge badge--marker">Admin</span>
          <% end %>

          <% if signed_in? %>
            <%# Fizzy-style account hub: everything personal lives behind one
                name button. Native popover — light-dismiss, zero JS. %>
            <button type="button" class="account-menu-button" popovertarget="account-menu">
              <%= Current.user.name %>
              <%= heroicon "chevron-down", variant: :outline %>
            </button>

            <div id="account-menu" class="account-menu" popover>
              <p class="account-menu__header">
                <span class="account-menu__name"><%= Current.user.name %></span>
                <span class="account-menu__email"><%= Current.user.email_address %></span>
              </p>

              <nav class="account-menu__nav">
                <%= link_to dashboard_path, class: "account-menu__link" do %>
                  <%= heroicon "home", variant: :outline %>
                  <%= t("nav.dashboard") %>
                <% end %>
                <%= link_to journal_entries_path, class: "account-menu__link" do %>
                  <%= heroicon "pencil-square", variant: :outline %>
                  <%= t("nav.journal") %>
                <% end %>
                <%= link_to account_path, class: "account-menu__link" do %>
                  <%= heroicon "user-circle", variant: :outline %>
                  <%= t("nav.account") %>
                <% end %>
                <%= link_to new_feedback_path, class: "account-menu__link" do %>
                  <%= heroicon "chat-bubble-left-ellipsis", variant: :outline %>
                  <%= t("nav.feedback") %>
                <% end %>
                <% if Current.user.can_edit_content? %>
                  <%# Admins land on the overview; editors on their main job — the moderation queue. %>
                  <%= link_to (Current.user.can_administer? ? admin_root_path : admin_lesson_suggestions_path), class: "account-menu__link" do %>
                    <%= heroicon "cog-6-tooth", variant: :outline %>
                    Admin
                  <% end %>
                <% end %>
              </nav>

              <%= button_to session_path, method: :delete, class: "account-menu__link account-menu__signout" do %>
                <%= heroicon "arrow-right-on-rectangle", variant: :outline %>
                <%= t("auth.sign_out") %>
              <% end %>
            </div>
          <% else %>
            <%= link_to t("auth.sign_in"), new_session_path, class: "nav__link",
                  aria: { current: ("page" if current_page?(new_session_path)) } %>
            <%= link_to t("auth.sign_up"), new_signup_path, class: "btn btn--small btn--reversed" %>
          <% end %>
        </div>
      </nav>
    </header>

    <%= render "shared/flash" %>
    <%= render "shared/welcome_letter" if flash[:welcome_letter] %>

    <main>
      <%= yield %>
    </main>

    <footer class="footer">
      <div class="container footer__inner">
        <div class="footer__brand-block">
          <a href="<%= root_path %>" class="brand">
            <%= image_tag "logo-ethernet.png", alt: "", class: "brand__mark", aria: { hidden: "true" } %>
            <span class="brand__text"><%= t("site.name") %></span>
          </a>
          <p class="footer__tagline"><%= t("site.tagline") %></p>
        </div>

        <nav class="footer__nav">
          <a href="<%= paths_path %>" class="footer__link"><%= t("nav.professions") %></a>
          <a href="<%= projects_path %>" class="footer__link"><%= t("nav.projects") %></a>
          <a href="<%= about_path %>" class="footer__link"><%= t("nav.about") %></a>
          <a href="<%= faq_path %>" class="footer__link"><%= t("nav.faq") %></a>
          <a href="<%= roadmap_path %>" class="footer__link"><%= t("nav.roadmap") %></a>
          <a href="<%= support_us_path %>" class="footer__link"><%= t("nav.support") %></a>
          <%# Signed-in readers write to the founder right on the site; guests go to Telegram. %>
          <% if signed_in? %>
            <a href="<%= new_feedback_path %>" class="footer__link"><%= t("footer.feedback") %></a>
          <% else %>
            <a href="<%= site_config.telegram_url %>" class="footer__link" target="_blank" rel="noopener"><%= t("footer.feedback") %></a>
          <% end %>
        </nav>

        <div class="footer__socials">
          <a href="<%= site_config.telegram_url %>" class="footer__social-link" target="_blank" rel="noopener" aria-label="Telegram">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a href="<%= site_config.github_url %>" class="footer__social-link" target="_blank" rel="noopener" aria-label="GitHub">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>

      <div class="container">
        <div class="footer__copy">
          <%= t("footer.copyright_html", year: Date.current.year, author_url: site_config.author_url) %>
        </div>
      </div>
    </footer>
  </body>
</html>
