<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc><%= site_config.url %>/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc><%= site_config.url %>/paths</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc><%= site_config.url %>/faq</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc><%= site_config.url %>/support_us</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  <% @paths.each do |path| %>
  <url>
    <loc><%= site_config.url %>/paths/<%= path.slug %></loc>
    <lastmod><%= path.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>
  <% @courses.each do |course| %>
  <url>
    <loc><%= site_config.url %>/courses/<%= course.slug %></loc>
    <lastmod><%= course.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>
  <% @lessons.each do |lesson| %>
  <url>
    <loc><%= site_config.url %>/lessons/<%= lesson.slug %></loc>
    <lastmod><%= lesson.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <% end %>
</urlset>
