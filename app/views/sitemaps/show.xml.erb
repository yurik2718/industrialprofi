<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://industrialprofi.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://industrialprofi.com/paths</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://industrialprofi.com/support_us</loc>
    <changefreq>monthly</changefreq>
    <priority>0.3</priority>
  </url>
  <% @paths.each do |path| %>
  <url>
    <loc>https://industrialprofi.com/paths/<%= path.slug %></loc>
    <lastmod><%= path.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <% end %>
  <% @lessons.each do |lesson| %>
  <url>
    <loc>https://industrialprofi.com/lessons/<%= lesson.slug %></loc>
    <lastmod><%= lesson.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  <% end %>
</urlset>
