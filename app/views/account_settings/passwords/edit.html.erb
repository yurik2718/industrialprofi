<% meta_title(t("account.password_change_title")) %>

<section class="section">
  <div class="container">
    <div class="auth">
      <h1 class="auth__title"><%= t("account.password_change_title") %></h1>

      <%= form_with url: account_password_path, method: :patch, class: "auth__form" do |f| %>
        <%= f.label :current_password, t("account.current_password"), class: "for-screen-reader" %>
        <%= f.password_field :current_password, required: true, autofocus: true,
              autocomplete: "current-password",
              placeholder: t("account.current_password"), class: "input" %>

        <%= f.label :password, t("auth.password_placeholder"), class: "for-screen-reader" %>
        <%= tag.input type: "password", name: "user[password]", required: true,
              minlength: 8, autocomplete: "new-password",
              placeholder: t("auth.password_placeholder"), class: "input" %>

        <%= tag.input type: "password", name: "user[password_confirmation]", required: true,
              minlength: 8, autocomplete: "new-password",
              placeholder: t("auth.password_confirmation"), class: "input" %>

        <%= f.submit t("account.save_password"), class: "btn btn--reversed btn--large auth__submit" %>
      <% end %>

      <p class="auth__alt"><%= link_to t("account.back"), account_path %></p>
    </div>
  </div>
</section>
