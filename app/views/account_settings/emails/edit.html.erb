<% meta_title(t("account.email_change_title")) %>

<section class="section">
  <div class="container">
    <div class="auth">
      <h1 class="auth__title"><%= t("account.email_change_title") %></h1>
      <p class="auth__subtitle"><%= t("account.email_change_hint") %></p>

      <%= form_with url: account_email_path, method: :post, class: "auth__form" do |f| %>
        <%= f.label :email_address, t("auth.email"), class: "for-screen-reader" %>
        <%= f.email_field :email_address, required: true, autofocus: true,
              autocomplete: "email",
              placeholder: t("account.new_email_placeholder"), class: "input" %>

        <%= f.submit t("account.send_code"), class: "btn btn--reversed btn--large auth__submit" %>
      <% end %>

      <p class="auth__alt"><%= link_to t("account.back"), account_path %></p>
    </div>
  </div>
</section>
