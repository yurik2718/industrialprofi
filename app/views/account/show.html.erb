<% meta_title(t("account.title")) %>

<section class="section">
  <div class="container">
    <div class="account-settings">
      <h1 class="account-settings__title"><%= t("account.title") %></h1>

      <%# Имя %>
      <div class="panel account-settings__card">
        <% if @name_errors.any? %>
          <p class="account-settings__error" role="alert"><%= @name_errors.first %></p>
        <% end %>
        <%= form_with url: account_path, method: :patch do |f| %>
          <div class="account-settings__field">
            <%= f.label :name, t("account.name_label"), class: "account-settings__label" %>
            <%= f.text_field :name, value: Current.user.name, name: "user[name]",
                  required: true, autocomplete: "name", class: "input" %>
          </div>
          <div class="account-settings__actions">
            <%= f.submit t("account.save"), class: "btn btn--reversed btn--small" %>
          </div>
        <% end %>
      </div>

      <%# Email %>
      <div class="panel account-settings__card">
        <div class="account-settings__field">
          <span class="account-settings__label"><%= t("account.email_section") %></span>
          <div class="account-settings__email-row">
            <span class="account-settings__email-value"><%= Current.user.email_address %></span>
            <%= link_to t("account.change_email"), edit_account_email_path, class: "account-settings__link" %>
          </div>
        </div>
      </div>

      <%# Письма %>
      <div class="panel account-settings__card">
        <%= form_with url: account_path, method: :patch do |f| %>
          <div class="account-settings__field">
            <span class="account-settings__label"><%= t("account.emails_section") %></span>
            <label class="account-settings__checkbox">
              <%= hidden_field_tag "user[reminder_emails]", "0", id: nil %>
              <%= check_box_tag "user[reminder_emails]", "1", Current.user.reminder_emails? %>
              <%= t("account.reminder_emails_label") %>
            </label>
            <p class="account-settings__hint"><%= t("account.reminder_emails_hint") %></p>
          </div>
          <div class="account-settings__actions">
            <%= f.submit t("account.save"), class: "btn btn--reversed btn--small" %>
          </div>
        <% end %>
      </div>

      <%# Пароль %>
      <div class="panel account-settings__card">
        <% if @password_errors.any? %>
          <p class="account-settings__error" role="alert"><%= @password_errors.first %></p>
        <% end %>
        <%= form_with url: account_password_path, method: :patch do |f| %>
          <div class="account-settings__field">
            <%= f.label :current_password, t("account.current_password"), class: "account-settings__label" %>
            <%= f.password_field :current_password, required: true,
                  autocomplete: "current-password", class: "input" %>
          </div>
          <div class="account-settings__field">
            <label class="account-settings__label"><%= t("account.new_password") %></label>
            <%= tag.input type: "password", name: "user[password]", required: true,
                  minlength: 8, autocomplete: "new-password", class: "input" %>
          </div>
          <div class="account-settings__field">
            <label class="account-settings__label"><%= t("auth.password_confirmation") %></label>
            <%= tag.input type: "password", name: "user[password_confirmation]", required: true,
                  minlength: 8, autocomplete: "new-password", class: "input" %>
          </div>
          <div class="account-settings__actions">
            <%= f.submit t("account.save_password"), class: "btn btn--reversed btn--small" %>
          </div>
        <% end %>
      </div>

      <%# Опасная зона %>
      <div class="panel account-settings__card account-settings__card--danger">
        <div class="account-settings__field">
          <span class="account-settings__label account-settings__label--danger"><%= t("account.danger_zone") %></span>
          <p class="account-settings__hint"><%= t("account.delete_warning") %></p>
        </div>
        <div class="account-settings__actions account-settings__actions--danger">
          <%= link_to new_account_deletion_path, class: "btn btn--small account-settings__danger-btn" do %>
            <%= heroicon "trash", variant: :outline %>
            <%= t("account.delete_account") %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</section>
