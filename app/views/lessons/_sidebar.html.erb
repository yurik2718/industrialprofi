<aside class="lesson-sidebar">
  <div class="sticky top-0 h-screen overflow-y-auto py-6 px-4">
    <a href="<%= path_path(@path) %>" class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-white transition">
      <%= heroicon("chevron-left", variant: :outline, options: { class: "w-4 h-4" }) %>
      <%= @path.title %>
    </a>

    <p class="mt-4 text-xs text-gray-500"><%= russian_pluralize(@path.lessons_count, :lesson) %></p>

    <nav class="mt-4 space-y-3" aria-label="<%= t('lessons.sidebar_title') %>">
      <% @lessons_by_stage.each do |stage, lessons| %>
        <details open class="group">
          <% if stage.present? %>
            <summary class="flex items-center justify-between cursor-pointer select-none py-1.5">
              <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider"><%= stage %></span>
              <%= heroicon("chevron-down", variant: :outline, options: { class: "w-4 h-4 text-gray-600 transition-transform group-open:rotate-180" }) %>
            </summary>
          <% end %>
          <ul class="mt-1 space-y-0.5">
            <% lessons.each do |lesson| %>
              <li>
                <a href="<%= lesson_path(lesson) %>"
                   class="sidebar-lesson-link <%= 'sidebar-lesson-active' if lesson.id == @lesson.id %>"
                   <%= raw('aria-current="page"') if lesson.id == @lesson.id %>>
                  <span class="truncate"><%= lesson.title %></span>
                </a>
              </li>
            <% end %>
          </ul>
        </details>
      <% end %>
    </nav>
  </div>
</aside>
