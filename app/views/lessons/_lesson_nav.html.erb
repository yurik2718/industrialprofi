<%# Inline edit prompt %>
<p class="mt-10 text-sm text-gray-500">
  <%= t("lessons.found_error_question") %>
  <%= link_to t("lessons.suggest_edit"),
      new_lesson_suggestion_path(lesson_slug: @lesson.slug),
      class: "lesson-edit-link" %>
</p>

<%# Lesson-to-lesson navigation %>
<nav class="mt-6 pt-6 border-t border-gray-700/30">
  <div class="flex items-center justify-between gap-4">
    <% if (prev = @lesson.prev_in_path) %>
      <%= link_to prev, class: "lesson-nav-pill" do %>
        <%= heroicon("chevron-left", variant: :outline, options: { class: "w-5 h-5" }) %>
        <%= t("lessons.previous_lesson") %>
      <% end %>
    <% else %>
      <span></span>
    <% end %>

    <% if (nxt = @lesson.next_in_path) %>
      <%= link_to nxt, class: "lesson-nav-pill" do %>
        <%= t("lessons.next_lesson") %>
        <%= heroicon("chevron-right", variant: :outline, options: { class: "w-5 h-5" }) %>
      <% end %>
    <% end %>
  </div>
</nav>
