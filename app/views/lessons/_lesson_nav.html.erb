<%# ── Footer links (two columns) ── %>
<div class="mt-10 pt-6 border-t border-gray-700/30 flex justify-between">
  <div class="flex flex-col gap-1.5">
    <a href="https://t.me/industrialprofi" class="lesson-footer-link" target="_blank" rel="noopener">
      <%= t("lessons.report_issue") %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
    </a>
    <a href="https://t.me/industrialprofi" class="lesson-footer-link" target="_blank" rel="noopener">
      <%= t("lessons.report_broken_link") %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
    </a>
    <a href="https://t.me/industrialprofi" class="lesson-footer-link" target="_blank" rel="noopener">
      <%= t("lessons.suggest_edit") %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
    </a>
  </div>
  <div class="flex flex-col items-end">
    <a href="https://t.me/industrialprofi" class="lesson-footer-link" target="_blank" rel="noopener">
      <%= t("lessons.see_changelog") %>
      <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
    </a>
  </div>
</div>

<%# ── Navigation buttons (three columns) ── %>
<div class="mt-10 pt-8 border-t border-gray-700/30">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <%# Previous %>
    <div>
      <% if @prev_lesson %>
        <a href="<%= lesson_path(@prev_lesson) %>" class="lesson-nav-pill">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9.75" stroke-opacity="0.5"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.25 8.25-3.75 3.75 3.75 3.75"/>
          </svg>
          <%= t("lessons.previous_lesson") %>
        </a>
      <% end %>
    </div>

    <%# Complete / Sign in %>
    <div>
      <a href="#" class="lesson-nav-cta" onclick="return false;">
        <%= t("lessons.sign_in_to_track") %>
      </a>
    </div>

    <%# Next %>
    <div>
      <% if @next_lesson %>
        <a href="<%= lesson_path(@next_lesson) %>" class="lesson-nav-pill">
          <%= t("lessons.next_lesson") %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9.75" stroke-opacity="0.5"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 8.25 3.75 3.75-3.75 3.75"/>
          </svg>
        </a>
      <% end %>
    </div>
  </div>
</div>
