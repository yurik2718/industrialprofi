<%# locals: (lesson:, bookmarked:) -%>
<%# Save-for-later toggle. One markup for every context (lesson page, project
    card) so the Turbo Stream replace can re-render it blindly; the card hides
    the text label via CSS and keeps just the icon. %>
<div id="<%= dom_id(lesson, :bookmark) %>" class="bookmark-toggle">
  <% if bookmarked %>
    <%= button_to lesson_bookmark_path(lesson), method: :delete,
          class: "bookmark-btn bookmark-btn--on",
          title: t("bookmarks.remove"), "aria-label": t("bookmarks.remove") do %>
      <%= heroicon "bookmark", variant: :solid %>
      <span class="bookmark-btn__label"><%= t("bookmarks.saved") %></span>
    <% end %>
  <% else %>
    <%= button_to lesson_bookmark_path(lesson), method: :post,
          class: "bookmark-btn",
          title: t("bookmarks.add"), "aria-label": t("bookmarks.add") do %>
      <%= heroicon "bookmark", variant: :outline %>
      <span class="bookmark-btn__label"><%= t("bookmarks.add") %></span>
    <% end %>
  <% end %>
</div>
