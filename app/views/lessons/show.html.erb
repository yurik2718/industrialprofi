<% meta_title(@lesson.title) %>
<% meta_description(@lesson.description.to_s.truncate(160)) %>
<% canonical_url("#{site_config.url}/lessons/#{@lesson.slug}") %>

<% content_for(:head) do %>
  <%= json_ld_tag(learning_resource_json_ld(@lesson)) %>
  <%= json_ld_tag(breadcrumb_json_ld([
    { title: t("breadcrumbs.home"), url: "#{site_config.url}/" },
    { title: t("paths.title"), url: "#{site_config.url}/paths" },
    { title: @path.title, url: "#{site_config.url}/paths/#{@path.slug}" },
    { title: @lesson.title, url: "#{site_config.url}/lessons/#{@lesson.slug}" }
  ])) %>
<% end %>

<main class="max-w-3xl mx-auto py-10 sm:py-14 px-4 sm:px-6 lg:px-8">
  <%= render "shared/breadcrumbs", crumbs: [
    { title: @path.title, path: path_path(@path) },
    { title: @lesson.title }
  ] %>

  <header class="mt-3 mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-ink leading-tight"><%= @lesson.title %></h1>
  </header>

  <article>
    <% if @lesson.has_description? %>
      <section id="why" class="lesson-intro scroll-mt-6">
        <p class="text-sm font-medium text-link mb-1"><%= t("lessons.why_section") %></p>
        <div class="lesson-prose"><%= lesson_content(@lesson, :description) %></div>
      </section>
    <% end %>

    <% if @lesson.has_body? %>
      <section id="study" class="mt-10 scroll-mt-6">
        <h2 class="lesson-heading"><%= t("lessons.study_section") %></h2>
        <div class="lesson-prose"><%= lesson_content(@lesson, :body) %></div>
      </section>
    <% end %>

    <% if @lesson.has_resources? %>
      <section id="resources" class="mt-10 scroll-mt-6">
        <h2 class="lesson-heading"><%= t("lessons.resources_section") %></h2>
        <ul class="mt-4 space-y-3">
          <%= render @lesson.resources.required %>
          <%= render @lesson.resources.optional %>
        </ul>
      </section>
    <% end %>

    <% if @lesson.has_task? %>
      <section id="task" class="mt-10 scroll-mt-6">
        <h2 class="lesson-heading"><%= t("lessons.task_section") %></h2>
        <div class="lesson-task">
          <div class="lesson-prose"><%= lesson_content(@lesson, :task) %></div>
        </div>
      </section>
    <% end %>

    <%= render "lessons/lesson_nav" %>
  </article>
</main>

<section class="border-t border-subtle bg-subtle-light">
  <div class="page-container py-16 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-ink"><%= t("landing.support_title") %></h2>
    <p class="mt-4 body-text max-w-lg mx-auto"><%= t("landing.support_subtitle") %></p>
    <div class="mt-8 flex items-center justify-center gap-4 flex-wrap">
      <%= link_to t("landing.contact_us_short"), support_us_path, class: "btn" %>
      <a href="<%= site_config.donate_url %>" class="btn btn--reversed" target="_blank" rel="noopener"><%= t("landing.donate") %></a>
    </div>
  </div>
</section>
