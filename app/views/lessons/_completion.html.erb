<%# locals: (lesson:, completed:, popped: false) -%>
<%# TOP-style end-of-lesson bar: completion toggle left, "next" always right.
    The toggle is one button — POST marks done, clicking it again un-marks. %>
<div id="<%= dom_id(lesson, :completion) %>" class="lesson-complete">
  <% if signed_in? %>
    <% if completed %>
      <%= button_to lesson_completion_path(lesson), method: :delete,
            class: "btn btn--large btn--positive lesson-complete__toggle",
            form_class: "lesson-complete__form",
            title: t("lessons.uncomplete") do %>
        <span class="lesson-complete__check<%= " lesson-complete__check--pop" if popped %>">
          <%= heroicon "check-circle", variant: :solid %>
        </span>
        <%= t("lessons.completed") %>
      <% end %>
    <% else %>
      <%= button_to lesson_completion_path(lesson), method: :post,
            class: "btn btn--large btn--reversed lesson-complete__toggle",
            form_class: "lesson-complete__form" do %>
        <span class="lesson-complete__check">
          <%= heroicon "check", variant: :outline %>
        </span>
        <%= t("lessons.mark_complete") %>
      <% end %>
    <% end %>
  <% else %>
    <p class="lesson-complete__signin">
      <%= t("lessons.sign_in_to_track_html",
            sign_up_link: link_to(t("auth.sign_up_action"), new_signup_path),
            sign_in_link: link_to(t("auth.sign_in_action"), new_session_path)) %>
    </p>
  <% end %>

  <div class="lesson-complete__side">
    <%# The completion bar does one job: mark done + continue. Journaling lives
        with the practice task itself (the .lesson-task-journal CTA), so it isn't
        duplicated here. %>
    <% if (nxt = lesson.next_in_path) %>
      <%= link_to nxt, class: "btn btn--large lesson-complete__next" do %>
        <%= t("lessons.go_next") %>
        <%= heroicon "arrow-right", variant: :outline %>
      <% end %>
    <% else %>
      <%= link_to path_path(lesson.path), class: "btn btn--large lesson-complete__next" do %>
        <%= t("lessons.back_to_path") %>
        <%= heroicon "arrow-right", variant: :outline %>
      <% end %>
    <% end %>
  </div>
</div>
