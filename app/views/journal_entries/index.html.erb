<% meta_title(t("journal.title")) %>

<section class="section">
  <div class="container container--reading journal">
    <div class="txt-align-center journal__intro">
      <h1 class="section-title"><%= t("journal.title") %></h1>
      <p class="section-subtitle"><%= t("journal.subtitle") %></p>
    </div>

    <% if @entries.any? %>
      <div class="journal__toolbar">
        <%= link_to new_journal_entry_path, class: "btn btn--reversed" do %>
          <%= heroicon "plus", variant: :outline %>
          <%= t("journal.new_entry") %>
        <% end %>
      </div>

      <div class="journal__entries">
        <% @entries.each do |entry| %>
          <article class="panel journal-entry">
            <header class="journal-entry__meta">
              <time datetime="<%= entry.created_at.to_date %>"><%= l(entry.created_at.to_date) %></time>
              <% if entry.lesson %>
                <%= link_to entry.lesson.title, lesson_path(entry.lesson), class: "journal-entry__lesson" %>
              <% end %>
              <span class="journal-entry__actions">
                <%= link_to t("journal.edit"), edit_journal_entry_path(entry), class: "journal-entry__action" %>
                <%= button_to t("journal.delete"), journal_entry_path(entry), method: :delete,
                      class: "journal-entry__action journal-entry__action--delete",
                      form: { data: { turbo_confirm: t("journal.confirm_delete") } } %>
              </span>
            </header>

            <% if entry.title.present? %>
              <h2 class="journal-entry__title"><%= entry.title %></h2>
            <% end %>

            <div class="prose journal-entry__body"><%= entry.body %></div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="journal__empty">
        <span class="journal__empty-icon"><%= heroicon "pencil-square", variant: :outline %></span>
        <p class="journal__empty-text"><%= t("journal.empty") %></p>
        <%= link_to t("journal.new_entry"), new_journal_entry_path, class: "btn btn--reversed btn--large" %>
      </div>
    <% end %>
  </div>
</section>
