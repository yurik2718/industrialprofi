<%= turbo_stream.replace dom_id(@lesson, :completion) do %>
  <%= render "lessons/completion", lesson: @lesson, completed: true %>
<% end %>

<%= turbo_stream.replace "lesson_sidebar" do %>
  <%= render "lessons/sidebar", course: @course, current_lesson: @lesson,
        lessons_by_stage: @lessons_by_stage, completed_ids: @completed_ids %>
<% end %>

<% if @celebration %>
  <%= turbo_stream.update :flash do %>
    <%= render "shared/flash_message", message: @celebration %>
  <% end %>
<% end %>

<%# Completing un-bookmarks (done ≠ saved for later); refresh the toggle if
    it's on the page — Turbo skips missing targets. %>
<%= turbo_stream.replace dom_id(@lesson, :bookmark) do %>
  <%= render "lessons/bookmark_button", lesson: @lesson, bookmarked: false %>
<% end %>
