<% meta_title(t("suggestions.page_title")) %>

<section class="admin-page">
  <div class="container container--reading">
    <%= render "shared/breadcrumbs", crumbs: [
      { title: @lesson.path.title, path: path_path(@lesson.path) },
      { title: @lesson.title, path: lesson_path(@lesson) },
      { title: t("suggestions.breadcrumb") }
    ] %>

    <header class="admin-header">
      <h1 class="admin-header__title"><%= t("suggestions.title") %></h1>
    </header>

    <p class="lesson-edit-prompt"><%= t("suggestions.subtitle", lesson: @lesson.title) %></p>

    <% if @suggestion.errors.any? %>
      <div class="admin-alert admin-alert--error">
        <% @suggestion.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with(model: @suggestion, url: lesson_suggestions_path) do |f| %>
      <%= f.hidden_field :lesson_id, value: @lesson.id %>

      <div class="admin-form__field">
        <label><%= t("suggestions.field_section") %></label>
        <%= f.select :section, [
          [t("suggestions.section_body"), "body"],
          [t("suggestions.section_task"), "task"],
          [t("suggestions.section_description"), "description"]
        ], {}, class: "input",
           data: {
             controller: "section-reload",
             "section-reload-url-value": new_lesson_suggestion_path(lesson_slug: @lesson.slug),
             action: "change->section-reload#navigate"
           } %>
      </div>

      <div class="admin-form__field admin-form__field--lg">
        <label><%= t("suggestions.field_content") %></label>
        <p class="admin-form__hint"><%= t("suggestions.field_content_hint") %></p>
        <%= f.rich_text_area :rich_body, class: "lexxy-content",
            data: { toolbar: { upload: false }.to_json } %>
      </div>

      <div class="admin-form__grid admin-form__field--lg">
        <div class="admin-form__field">
          <label><%= t("suggestions.field_name") %> *</label>
          <%= f.text_field :author_name,
              placeholder: t("suggestions.name_placeholder"),
              class: "input" %>
        </div>
        <div class="admin-form__field">
          <label><%= t("suggestions.field_contact") %></label>
          <%= f.text_field :author_contact,
              placeholder: t("suggestions.contact_placeholder"),
              class: "input" %>
        </div>
      </div>

      <div class="admin-form__actions">
        <%= f.submit t("suggestions.submit"), class: "btn btn--reversed" %>
        <a href="<%= lesson_path(@lesson) %>" class="btn"><%= t("admin.cancel") %></a>
      </div>
    <% end %>
  </div>
</section>
