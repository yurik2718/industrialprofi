<% meta_title(t("suggestions.page_title")) %>

<section class="section-padded">
  <div class="content-container">
    <%= render "shared/breadcrumbs", crumbs: [
      { title: @lesson.path.title, path: path_path(@lesson.path) },
      { title: @lesson.title, path: lesson_path(@lesson) },
      { title: t("suggestions.breadcrumb") }
    ] %>

    <div class="mt-8">
      <h1 class="text-2xl font-bold text-white"><%= t("suggestions.title") %></h1>
      <p class="mt-2 text-sm text-gray-400">
        <%= t("suggestions.subtitle", lesson: @lesson.title) %>
      </p>
    </div>

    <% if @suggestion.errors.any? %>
      <div class="mt-4 p-3 rounded-lg bg-red-900/30 border border-red-500/30 text-sm text-red-400">
        <% @suggestion.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with(model: @suggestion, url: lesson_suggestions_path) do |f| %>
      <%= f.hidden_field :lesson_id, value: @lesson.id %>

      <%# Section selector %>
      <div class="mt-6">
        <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("suggestions.field_section") %></label>
        <%= f.select :section, [
          [t("suggestions.section_body"), "body"],
          [t("suggestions.section_task"), "task"],
          [t("suggestions.section_description"), "description"]
        ], {}, class: "bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-teal-500/50 transition" %>
      </div>

      <%# Markdown textarea with current content %>
      <div class="mt-4">
        <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("suggestions.field_content") %></label>
        <p class="text-xs text-gray-500 mb-2"><%= t("suggestions.field_content_hint") %></p>
        <%= f.text_area :body_markdown,
            value: @suggestion.body_markdown.presence || @lesson.send(@section),
            rows: 16,
            class: "w-full bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-gray-300 font-mono focus:outline-none focus:border-teal-500/50 transition resize-y" %>
      </div>

      <%# Author info %>
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("suggestions.field_name") %> *</label>
          <%= f.text_field :author_name,
              placeholder: t("suggestions.name_placeholder"),
              class: "w-full bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-teal-500/50 transition" %>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-400 mb-1"><%= t("suggestions.field_contact") %></label>
          <%= f.text_field :author_contact,
              placeholder: t("suggestions.contact_placeholder"),
              class: "w-full bg-navy-lighter border border-gray-700/50 rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-teal-500/50 transition" %>
        </div>
      </div>

      <div class="mt-6 flex items-center gap-3">
        <%= f.submit t("suggestions.submit"), class: "btn-primary cursor-pointer" %>
        <a href="<%= lesson_path(@lesson) %>" class="btn-outline"><%= t("admin.cancel") %></a>
      </div>
    <% end %>
  </div>
</section>
