<% meta_title(t("auth.new_password_title")) %>

<section class="section">
  <div class="container auth">
    <h1 class="auth__title"><%= t("auth.new_password_title") %></h1>

    <%= form_with url: password_path(params[:token]), method: :patch, class: "auth__form" do |form| %>
      <div class="auth__field">
        <%= form.label :password, t("auth.password") %>
        <%= form.password_field :password, required: true, autofocus: true, minlength: 8,
              autocomplete: "new-password", class: "input" %>
        <p class="auth__hint"><%= t("auth.password_hint") %></p>
      </div>

      <div class="auth__field">
        <%= form.label :password_confirmation, t("auth.password_confirmation") %>
        <%= form.password_field :password_confirmation, required: true, minlength: 8,
              autocomplete: "new-password", class: "input" %>
      </div>

      <%= form.submit t("auth.save_password"), class: "btn btn--reversed btn--large auth__submit" %>
    <% end %>
  </div>
</section>
